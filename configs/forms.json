{
  "forms": {
    "product_form": {
      "title_key": "form.product.title",
      "submit_label_key": "action.save",
      "collection": "products",
      "fields": [
        {"name": "product_name", "label_key": "field.product_name", "type": "text", "required": true},
        {"name": "product_code_preview", "label_key": "field.product_code", "type": "readonly", "required": true},
        {"name": "owner_type", "label_key": "field.owner_type", "type": "select", "required": true},
        {"name": "owner_email", "label_key": "field.owner_email", "type": "text", "required": true},
        {"name": "category", "label_key": "field.category", "type": "select", "required": true},
        {"name": "subcategory", "label_key": "field.subcategory", "type": "select", "required": true},
        {"name": "description", "label_key": "field.description", "type": "text"},
        {"name": "images", "label_key": "field.product_images", "type": "file", "multiple": true},
        {"name": "unit", "label_key": "field.unit", "type": "text"},
        {"name": "available_quantity", "label_key": "field.available_quantity", "type": "number"},
        {"name": "marketplace_price", "label_key": "field.marketplace_price", "type": "number"},
        {"name": "manditrade_price", "label_key": "field.manditrade_price", "type": "number"}
      ]
    }
  }
}
