{
  "app_name": "MandiTrade Next",
  "version": "0.1.0",
  "default_role": "public_buyer",
  "default_language": "en",
  "default_landing": {
    "platform_admin": "dashboard",
    "manufacturer": "dashboard",
    "mahajan": "dashboard",
    "public_buyer": "marketplace",
    "worker": "dashboard"
  },
  "ui": {
    "languages": {
      "preferred_order": ["en", "hi", "bn", "mr"],
      "show_native_names": true
    },
    "product_grid": {
      "columns": {
        "default": 3,
        "marketplace": 3,
        "manditrade": 3,
        "admin": 3
      }
    },
    "product_gallery": {
      "card": {
        "badge_mode": "counter",
        "open_button_label_key": "ui.open_images"
      },
      "slideshow": {
        "show_thumbnail_strip": true,
        "max_thumbnail_count": 6,
        "show_image_counter": true,
        "show_image_file_name": true
      }
    }
  },
  "storage_mode": "drive_only",
  "admin_drive_enabled": true,
  "debug_auth": true
}
